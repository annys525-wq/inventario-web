<UserControl x:Class="InventarioApp.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InventarioApp.Views"
             xmlns:models="clr-namespace:InventarioApp.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             FontFamily="{StaticResource SegoeFluent}">

    <UserControl.Resources>
        <!-- Proveedor de Enums de Roles para el ComboBox -->
        <ObjectDataProvider x:Key="RolesEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:UserRole"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <!-- Si el usuario no tiene acceso, muestra cartel de denegación -->
        <Grid Visibility="{Binding HasAccess, Converter={x:Static Paragraph.FontSizeProperty}, ConverterParameter=Collapsed}">
            <Border Background="#200a0b" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="6" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🔒 ACCESO DENEGADO" Foreground="{StaticResource DangerBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <TextBlock Text="El panel de control de usuarios y auditoría es exclusivo para administradores de la empresa." Foreground="{StaticResource TextWhiteBrush}" FontSize="13" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    <TextBlock Text="Este intento de acceso ha sido registrado en la bitácora de seguridad." Foreground="{StaticResource TextDimBrush}" FontSize="11" TextAlignment="Center" FontWeight="Italic"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Interfaz CRUD Completa (Visible si HasAccess es True) -->
        <Grid Visibility="{Binding HasAccess, Converter={x:Static Paragraph.FontSizeProperty}, ConverterParameter=Visible}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/> <!-- Lista de Usuarios -->
                <ColumnDefinition Width="2*"/> <!-- Formulario Detalle -->
            </Grid.ColumnDefinitions>

            <!-- 1. PANEL DE LISTADO (IZQUIERDA) -->
            <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Cabecera / Buscador -->
                        <RowDefinition Height="*"/>    <!-- Tabla -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Usuarios Registrados en el Sistema" Foreground="{StaticResource TextWhiteBrush}" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="Selecciona un registro para ver detalles o editar." Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Actualizar" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Tabla de Usuarios -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding UsersList}" SelectedItem="{Binding SelectedUser}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Usuario" Binding="{Binding Username}" Width="100"/>
                            <DataGridTextColumn Header="Nombre Completo" Binding="{Binding FullName}" Width="160"/>
                            <DataGridTextColumn Header="Correo Electrónico" Binding="{Binding Email}" Width="170"/>
                            <DataGridTextColumn Header="Rol Asignado" Binding="{Binding Role}" Width="100"/>
                            <DataGridTemplateColumn Header="Estado" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="5,2" HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                            <Setter Property="Background" Value="#444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="9" FontWeight="Bold" TextAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="ACTIVO"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="INACTIVO"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 2. PANEL DE DETALLE / FORMULARIO (DERECHA) -->
            <Border Grid.Column="1" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Título Formulario -->
                        <RowDefinition Height="*"/>    <!-- Campos Formulario -->
                        <RowDefinition Height="Auto"/> <!-- Botones Operaciones -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Foreground="{StaticResource TextWhiteBrush}" FontSize="15" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Crear Nuevo Usuario"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedUser, Converter={x:Static Paragraph.FontSizeProperty}, ConverterParameter=IsNull}" Value="False">
                                            <Setter Property="Text" Value="Editar Usuario Existente"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Asigna credenciales y permisos corporativos." Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                    </StackPanel>

                    <!-- Formulario de Entrada -->
                    <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewer}" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                        <StackPanel Margin="0,0,5,0">
                            <!-- Nombre de Usuario -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Nombre de Usuario (Login)" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding UsernameInput, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center"/>
                            </StackPanel>
 
                            <!-- Contraseña -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Contraseña" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding PasswordInput, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center" ToolTip="Dejar en blanco para conservar clave al editar."/>
                                <TextBlock Text="* Requerido para usuarios nuevos. Al editar, llene solo si desea cambiar la clave." Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,3,0,0" FontStyle="Italic"/>
                            </StackPanel>
 
                            <!-- Nombre Completo -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Nombre Completo" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding FullNameInput, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center"/>
                            </StackPanel>
 
                            <!-- Correo Electrónico -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Correo Electrónico" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding EmailInput, UpdateSourceTrigger=PropertyChanged}" Height="34" VerticalContentAlignment="Center"/>
                            </StackPanel>
 
                            <!-- Rol Empresarial -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Rol Asignado" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding Source={StaticResource RolesEnum}}" SelectedItem="{Binding RoleInput}" Height="34" VerticalContentAlignment="Center"/>
                            </StackPanel>
 
                            <!-- Estado Activo/Inactivo -->
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,12">
                                <CheckBox IsChecked="{Binding IsActiveInput}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Usuario Activo (Permite el inicio de sesión)" Foreground="{StaticResource TextWhiteBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
 
                            <Border Background="#1b1b1c" CornerRadius="4" Padding="12" Margin="0,10,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Matriz de Permisos del Rol Seleccionado:" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                                    
                                    <!-- Muestra permisos dinámicos según el Rol cargado en el ComboBox -->
                                    <StackPanel Visibility="{Binding RoleInput, Converter={x:Static Paragraph.FontSizeProperty}, ConverterParameter=Administrador}">
                                        <TextBlock Text="• USER_CRUD (Crear/Modificar Usuarios)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• VIEW_AUDIT_LOGS (Ver Logs de Accesos)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• CRM_WRITE &amp; CRM_READ (Gestión de Clientes)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• STOCK_WRITE &amp; STOCK_READ (Inventario y Kardex)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• SALES_WRITE / PURCHASES_WRITE (Facturación y Compras)" Foreground="LightGreen" FontSize="10"/>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding RoleInput, Converter={x:Static Paragraph.FontSizeProperty}, ConverterParameter=Vendedor}">
                                        <TextBlock Text="• CRM_WRITE &amp; CRM_READ (Gestión de Clientes)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• STOCK_READ (Lectura de Existencias)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• SALES_WRITE (Facturación y Ventas)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="❌ Acceso denegado a CRUD de Usuarios y Auditoría" Foreground="#ff5a5a" FontSize="10"/>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding RoleInput, Converter={x:Static Paragraph.FontSizeProperty}, ConverterParameter=Bodega}">
                                        <TextBlock Text="• STOCK_READ &amp; STOCK_WRITE (Lectura/Escritura y Ajuste de Stock)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="• PURCHASES_WRITE (Registrar compras y recepción)" Foreground="LightGreen" FontSize="10"/>
                                        <TextBlock Text="❌ Acceso denegado a Facturación y CRM de Clientes" Foreground="#ff5a5a" FontSize="10"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Botones de Operaciones CRUD -->
                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Nuevo -->
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/> <!-- Eliminar -->
                            <ColumnDefinition Width="Auto"/> <!-- Guardar -->
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Nuevo" Command="{Binding ClearFormCommand}" Style="{StaticResource SecondaryButton}" Padding="15,8"/>
                        
                        <Button Grid.Column="2" Content="Eliminar" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Padding="15,8" Margin="0,0,10,0"/>
                        <Button Grid.Column="3" Content="Guardar Registro" Command="{Binding SaveCommand}" Padding="20,8"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
